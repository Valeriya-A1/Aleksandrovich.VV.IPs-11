<Window x:Class="Aleksandrovich.VV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" 
        Height="500" 
        Width="395"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="txtDisplay" 
                 Grid.Row="0" 
                 FontSize="36" 
                 Text="0" 
                 TextAlignment="Right"
                 IsReadOnly="True"
                 Background="White"
                 BorderBrush="Black"
                 BorderThickness="2"
                 Margin="5"/>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="(" FontSize="24" Margin="3" Click="Bracket_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content=")" FontSize="24" Margin="3" Click="Bracket_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="^" FontSize="24" Margin="3" Click="Operator_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" FontSize="24" Margin="3" Click="Operator_Click"/>
            <Button Grid.Row="1" Grid.Column="0" Content="1" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="2" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="3" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" FontSize="24" Margin="3" Click="Operator_Click"/>
            <Button Grid.Row="2" Grid.Column="0" Content="4" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" FontSize="24" Margin="3" Click="Operator_Click"/>
            <Button Grid.Row="3" Grid.Column="0" Content="7" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="1" Content="8" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="2" Content="9" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" FontSize="24" Margin="3" Click="Operator_Click"/>
            <Button Grid.Row="4" Grid.Column="0" Content="C" FontSize="24" Margin="3" Click="Clear_Click"/>
            <Button Grid.Row="4" Grid.Column="1" Content="0" FontSize="24" Margin="3" Click="Number_Click"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." FontSize="24" Margin="3" Click="Dot_Click"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" FontSize="24" Margin="3" Click="Equals_Click"/>
        </Grid>
    </Grid>
</Window>


